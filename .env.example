# ── IsotopeAI Self-Host Configuration ──────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to git — it contains secret keys.

# Server port (default: 3000)
PORT=3000

# ── Supabase ─────────────────────────────────────────────────────────────────
# Option A: Use your OWN free Supabase project (recommended — you own the data)
#   1. Create free project at https://supabase.com
#   2. Run isotope-schema.sql in the SQL Editor
#   3. Paste your Project URL, anon key, and service_role key below
#
# Option B: Leave blank to use the original IsotopeAI Supabase project
#   (community features may be limited without service_role key)

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...your-anon-key...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...your-service-role-key...

# ── AI Features (optional) ───────────────────────────────────────────────────
# Get a free Gemini key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Get a free Groq key at: https://console.groq.com/keys
GROQ_API_KEY=
